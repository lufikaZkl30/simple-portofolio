    <!-- Custom CSS -->
    <style>
        /* Base styling */
        body {
            background-color: theme('colors.light.bg');
            color: theme('colors.slate.900');
            transition: background-color 0.5s ease, color 0.5s ease;
            overflow-x: hidden;
        }

        .dark body {
            background-color: theme('colors.dark.bg');
            color: theme('colors.white');
        }

        /* Tekstur Noise Premium untuk Mode Gelap */
        .bg-noise {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: -2;
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        
        .dark .bg-noise {
            opacity: 0.04;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        }

        /* Typography layering for Hero */
        .text-layered {
            color: transparent;
            -webkit-text-stroke: 1px rgba(0,0,0,0.1);
            position: relative;
        }
        
        .dark .text-layered {
            -webkit-text-stroke: 1px rgba(255,255,255,0.05);
        }

        .text-layered::before {
            content: attr(data-text);
            position: absolute;
            left: 0;
            top: 0;
            width: 0;
            height: 100%;
            color: theme('colors.slate.900');
            -webkit-text-stroke: 0px;
            overflow: hidden;
            animation: fillText 4s ease-in-out infinite alternate;
        }

        .dark .text-layered::before {
            color: rgba(255, 255, 255, 0.95);
            text-shadow: 0 0 35px rgba(59, 130, 246, 0.3);
        }

        @keyframes fillText {
            0% { width: 0; }
            100% { width: 100%; }
        }

        /* Glassmorphism Utilities */
        .glass-panel {
            background: theme('colors.light.surface');
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid theme('colors.light.border');
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .dark .glass-panel {
            background: theme('colors.dark.glass');
            border: 1px solid theme('colors.dark.border');
            box-shadow: 0 15px 35px -10px rgba(0,0,0,0.8), inset 0 1px 0 rgba(255,255,255,0.04);
        }

        .glass-panel:hover {
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
            border-color: rgba(0,0,0,0.15);
            transform: translateY(-2px);
        }

        .dark .glass-panel:hover {
            box-shadow: 0 15px 40px -5px rgba(59, 130, 246, 0.2), inset 0 1px 0 rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.12);
        }

        /* Glowing Border Effect */
        .glow-border {
            position: relative;
        }
        
        .glow-border::before {
            content: "";
            position: absolute;
            inset: -1px;
            border-radius: inherit;
            padding: 1px;
            background: linear-gradient(45deg, transparent, rgba(0,0,0,0.1), transparent);
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .dark .glow-border::before {
            background: linear-gradient(45deg, transparent, theme('colors.accent.blue'), theme('colors.accent.orange'), transparent);
            background-size: 200% 200%;
            animation: panGlow 4s linear infinite;
        }

        @keyframes panGlow {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .glow-border:hover::before {
            opacity: 1;
        }

        /* Cinematic Background Elements (Orbs) */
        .bg-glow-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            z-index: -1;
            opacity: 0.5;
            transition: opacity 0.5s ease;
        }
        
        .dark .bg-glow-orb.orb-1 {
            opacity: 0.15;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.8) 0%, rgba(0,0,0,0) 70%);
        }

        .dark .bg-glow-orb.orb-2 {
            opacity: 0.12;
            background: radial-gradient(circle, rgba(249, 115, 22, 0.6) 0%, rgba(0,0,0,0) 70%);
        }

        /* Scroll Reveal Animation Classes */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        .delay-100 { transition-delay: 100ms; }
        .delay-200 { transition-delay: 200ms; }
        .delay-300 { transition-delay: 300ms; }

        /* Mouse Follower Glow */
        #mouse-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(0,0,0,0.03) 0%, transparent 60%);
            border-radius: 50%;
            pointer-events: none;
            transform: translate(-50%, -50%);
            z-index: 9999;
            transition: background 0.5s ease;
            mix-blend-mode: multiply;
        }

        .dark #mouse-glow {
            background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 60%);
            mix-blend-mode: screen;
        }

        /* Hide scrollbar for features */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        
        /* Modal setup */
        body.modal-open {
            overflow: hidden;
        }
    </style>
</head>
