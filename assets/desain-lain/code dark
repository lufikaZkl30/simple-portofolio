    <!-- Logika JavaScript -->
    <script>
        // Inisialisasi Ikon Lucide
        lucide.createIcons();

        // Atur tahun saat ini di footer
        document.getElementById('year').textContent = new Date().getFullYear();

        // --- Logika Ganti Tema ---
        const themeToggleBtn = document.getElementById('theme-toggle');
        const htmlElement = document.documentElement;
        
        // Periksa penyimpanan lokal atau preferensi sistem
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            htmlElement.classList.add('dark');
        } else {
            htmlElement.classList.remove('dark');
        }

        themeToggleBtn.addEventListener('click', () => {
            htmlElement.classList.toggle('dark');
            if (htmlElement.classList.contains('dark')) {
                localStorage.theme = 'dark';
            } else {
                localStorage.theme = 'light';
            }
        });

        // --- Animasi Ungkap Saat Digulir (Intersection Observer) ---
        const revealElements = document.querySelectorAll('.reveal');
        
        const revealOptions = {
            threshold: 0.15,
            rootMargin: "0px 0px -50px 0px"
        };

        const revealObserver = new IntersectionObserver(function(entries, observer) {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add('active');
                observer.unobserve(entry.target); // Jalankan sekali
            });
        }, revealOptions);

        revealElements.forEach(el => revealObserver.observe(el));

        // --- Efek Parallax Mouse untuk Elemen Hero ---
        const parallaxElements = document.querySelectorAll('.parallax-el');
        const heroSection = document.querySelector('section');

        heroSection.addEventListener('mousemove', (e) => {
            const x = e.clientX / window.innerWidth - 0.5;
            const y = e.clientY / window.innerHeight - 0.5;

            parallaxElements.forEach(el => {
                const speed = el.getAttribute('data-speed');
                const xOffset = x * speed * 30;
                const yOffset = y * speed * 30;
                
                el.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
            });
        });
        
        heroSection.addEventListener('mouseleave', () => {
             parallaxElements.forEach(el => {
                 el.style.transform = `translate(0px, 0px)`;
                 el.style.transition = `transform 0.5s ease`;
             });
        });
        heroSection.addEventListener('mouseenter', () => {
             parallaxElements.forEach(el => {
                 el.style.transition = `none`;
             });
        });


        // --- Efek Cahaya Pengikut Mouse ---
        const glow = document.getElementById('mouse-glow');
        
        window.addEventListener('mousemove', (e) => {
            // Menggunakan requestAnimationFrame untuk performa yang lebih halus
            requestAnimationFrame(() => {
                glow.style.left = e.clientX + 'px';
                glow.style.top = e.clientY + 'px';
            });
        });

        // Sembunyikan cahaya saat meninggalkan jendela
        document.addEventListener('mouseleave', () => {
            glow.style.opacity = '0';
        });
        document.addEventListener('mouseenter', () => {
            glow.style.opacity = '1';
        });


        // --- Logika Modal ---
        const modal = document.getElementById('project-modal');
        const modalContentWrapper = document.getElementById('modal-content-wrapper');
        
        // Data Proyek Tiruan
        const projectData = {
            proj1: {
                title: "Dasbor Nova Financial",
                img: "https://images.unsplash.com/photo-1600132806370-bf17e65e942f?q=80&w=2000&auto=format&fit=crop",
                desc: "UI dasbor komprehensif untuk startup fintech modern. Tujuannya adalah mengambil data keuangan yang kompleks dan menyajikannya dalam format yang bersih dan mudah dicerna menggunakan teknik visualisasi data tingkat lanjut dan alur pengguna yang intuitif. Dirancang dengan pendekatan mode gelap pertama untuk mengurangi ketegangan mata bagi pengguna berat.",
                tags: ["Desain UI/UX", "Figma", "Tailwind CSS", "JavaScript"],
                features: ["Bagan interaktif", "Dukungan mode Gelap/Terang", "Tabel data responsif", "Sistem desain berbasis komponen"]
            },
            proj2: {
                title: "Tema Portofolio DevSpace",
                img: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=2000&auto=format&fit=crop",
                desc: "Template portofolio premium yang dioptimalkan untuk mode gelap yang dirancang khusus untuk para developer. Berfokus pada efek pencahayaan sinematik, glassmorphism, dan animasi gulir halus tanpa bergantung pada kerangka kerja (framework) yang berat.",
                tags: ["HTML", "Vanilla CSS", "Desain UI"],
                features: ["Nol dependensi", "Animasi CSS kustom", "Struktur HTML semantik", "Skor Lighthouse sempurna"]
            },
            proj3: {
                title: "Konsep Aura Commerce",
                img: "https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?q=80&w=2000&auto=format&fit=crop",
                desc: "Prototipe fidelitas tinggi untuk merek e-commerce mode minimalis. Desainnya menekankan gambar besar, ruang putih yang luas, dan interaksi mikro yang sangat halus untuk menciptakan nuansa belanja premium.",
                tags: ["Prototyping", "Riset Pengguna", "Wireframing"],
                features: ["Prototipe Figma yang kompleks", "Pemetaan alur pengguna", "Desain set ikon kustom", "Perencanaan interaksi mikro"]
            },
            proj4: {
                title: "Aplikasi Pelacak Metrik",
                img: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2000&auto=format&fit=crop",
                desc: "Antarmuka aplikasi web responsif yang dirancang untuk melacak kebiasaan harian dan metrik produktivitas. Dilengkapi dengan tata letak berbasis kartu yang bersih dengan palet warna yang menenangkan.",
                tags: ["Build Frontend", "Desain Responsif", "CSS Grid"],
                features: ["Tata letak mobile-first", "Arsitektur CSS Grid", "Gaya form kustom", "Rasio kontras yang dapat diakses"]
            }
        };

        function openModal(projectId) {
            const data = projectData[projectId];
            if(!data) return;

            // Isi Data
            document.getElementById('modal-title').textContent = data.title;
            document.getElementById('modal-image').src = data.img;
            document.getElementById('modal-desc').textContent = data.desc;
            
            // Isi Tag
            const tagsContainer = document.getElementById('modal-tags');
            tagsContainer.innerHTML = '';
            data.tags.forEach(tag => {
                const span = document.createElement('span');
                span.className = 'text-xs font-mono px-3 py-1.5 rounded-full bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10';
                span.textContent = tag;
                tagsContainer.appendChild(span);
            });

            // Isi Fitur
            const featuresContainer = document.getElementById('modal-features');
            featuresContainer.innerHTML = '';
            data.features.forEach(feature => {
                const li = document.createElement('li');
                li.textContent = feature;
                featuresContainer.appendChild(li);
            });

            // Tampilkan Modal
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.classList.add('modal-open'); // Cegah pengguliran latar belakang
            
            // Picu animasi
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                modalContentWrapper.classList.remove('scale-95');
            }, 10);
        }

        function closeModal() {
            modal.classList.add('opacity-0');
            modalContentWrapper.classList.add('scale-95');
            
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                document.body.classList.remove('modal-open');
            }, 300); // Sesuaikan dengan durasi transisi
        }

        // Tutup modal dengan tombol Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
                closeModal();
            }
        });
    </script>
</body>
