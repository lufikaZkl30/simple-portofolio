        .dark ::-webkit-scrollbar-thumb { background: #404040; }

        /* Custom Cartoon Arrow Cursor */
        @media (pointer: fine) {
            #custom-cursor {
                position: fixed;
                pointer-events: none;
                transform: translate(-3px, -3px);
                z-index: 9999;
                will-change: transform, left, top;
            }
            
            #custom-cursor svg {
                width: 36px;
                height: 36px;
                transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), fill 0.3s, stroke 0.3s;
                transform-origin: 3px 3px; 
                filter: drop-shadow(2px 4px 6px rgba(0,0,0,0.15));
                fill: #f59e0b;
                stroke: #171717;
            }

            .dark #custom-cursor svg {
                filter: drop-shadow(2px 4px 6px rgba(0,0,0,0.6));
                stroke: #ffffff;
            }

            /* Hover state for interactive elements */
            body:has(a:hover) #custom-cursor svg, 
            body:has(button:hover) #custom-cursor svg, 
            body:has(.magnetic:hover) #custom-cursor svg {
                transform: scale(1.3) rotate(-10deg);
                fill: #ffffff;
                stroke: #f59e0b;
            }

            .dark body:has(a:hover) #custom-cursor svg, 
            .dark body:has(button:hover) #custom-cursor svg, 
            .dark body:has(.magnetic:hover) #custom-cursor svg {
                fill: #171717;
                stroke: #f59e0b;
            }
        }
        @media (pointer: coarse) {
            body { cursor: auto; }
            #custom-cursor { display: none; }
        }

        /* Editorial Text Stroke */
        .text-stroke {
            -webkit-text-stroke: 1px rgba(0, 0, 0, 0.15);
            color: transparent;
        }
        .dark .text-stroke {
            -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
        }

        /* 4. Glassmorphism / Premium Neumorphic Cards */
        .ui-card {
            background: #ffffff;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid transparent;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            transition: all 0.5s ease;
        }
        .dark .ui-card {
            background: rgba(38, 38, 38, 0.7); /* neutral-800/70 */
            border-color: #404040; /* neutral-700 */
            box-shadow: 0 0 25px rgba(245, 158, 11, 0.1);
        }
        .ui-card:hover {
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }
        .dark .ui-card:hover {
            box-shadow: 0 0 35px rgba(245, 158, 11, 0.25);
        }

        /* 3D Perspective */
        .perspective-1000 { perspective: 1000px; transform-style: preserve-3d; }
        .tilt-card { will-change: transform; }

        /* Scroll Reveal Utility */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .reveal-left { transform: translateX(-40px); }
        .reveal-right { transform: translateX(40px); }
        .reveal.active { opacity: 1; transform: translate(0, 0); }
        .delay-100 { transition-delay: 100ms; }
        .delay-200 { transition-delay: 200ms; }

        /* Keyframe Animations */
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(2deg); }
        }
        @keyframes bounce-slow {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(10px); }
        }
        .animate-float { animation: float 6s ease-in-out infinite; }
        .animate-bounce-slow { animation: bounce-slow 3s ease-in-out infinite; }

        /* Magnetic Wrappers */
        .magnetic-wrap { display: inline-block; }
        .magnetic { transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1); will-change: transform; }

        /* tambahan sedikit custom */
        /* Global Smooth Glow Background */
        body {
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed;
            top: -200px;
            right: -200px;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(245,158,11,0.10), transparent 70%);
